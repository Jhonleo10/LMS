# PostgreSQL connection (required — Prisma uses postgresql provider)
DATABASE_URL="postgresql://user:password@localhost:5432/lms"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Local development
NEXTAUTH_URL="http://localhost:3000"

# On Vercel, NEXTAUTH_URL is set automatically per deployment via VERCEL_URL in next.config.mjs.
# You can still override it here for a custom production domain:
# NEXTAUTH_URL="https://your-custom-domain.com"
