# ─── Required (local + Vercel Production) ───────────────────────────────────

# Local Docker PostgreSQL (run: npm run db:up)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lms"

# Session signing — generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Local only
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Production (custom domain) ────────────────────────────────────────
# Set ONLY on Production environment if you use a custom domain:
# NEXTAUTH_URL="https://your-custom-domain.com"
#
# Do NOT set NEXTAUTH_URL to localhost on Vercel.
# Do NOT set NEXTAUTH_URL on Preview if you test preview URLs — Vercel sets
# VERCEL_URL automatically and the app derives NEXTAUTH_URL from it at runtime.

# ─── Optional ───────────────────────────────────────────────────────────────
# AUTH_SECRET — alias for NEXTAUTH_SECRET (Auth.js v5 name; also supported here)
# AUTH_URL — alias for NEXTAUTH_URL
# AUTH_DEBUG=true — log auth flow to Vercel function logs (disable in prod when done)

# NOT USED (no OAuth in this app):
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, DIRECT_URL
