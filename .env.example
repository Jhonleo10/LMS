# ─── Required on Vercel (Production + Preview) ─────────────────────────────

DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
NEXTAUTH_SECRET="paste-output-of-openssl-rand-base64-32"

# ─── Local development ───────────────────────────────────────────────────────

# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lms"
# NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Production ONLY (custom domain) ─────────────────────────────────
#
# Set NEXTAUTH_URL only if you use a custom domain on Production:
# NEXTAUTH_URL="https://your-custom-domain.com"
#
# RULES:
# ✗ Never set NEXTAUTH_URL=http://localhost:3000 on Vercel
# ✗ Do not set NEXTAUTH_URL on Preview deployments (app auto-detects from request host)
# ✓ NEXTAUTH_SECRET must exist in Production AND Preview environments
# ✓ DATABASE_URL must point to your production PostgreSQL (not SQLite file:./dev.db)

# ─── Optional debugging ──────────────────────────────────────────────────────
# AUTH_DEBUG=true

# NOT USED: AUTH_URL, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, DIRECT_URL
# (AUTH_SECRET / AUTH_URL work as aliases if you prefer Auth.js v5 names)
